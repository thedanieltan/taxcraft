{
  "name": "@taxcraft/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Stateless HTTP API and reference web server for TaxCraft.",
  "exports": "./src/app.js",
  "dependencies": {
    "@taxcraft/catalog": "0.1.0",
    "@taxcraft/core": "0.1.0",
    "@taxcraft/country-flat-rate": "0.1.0",
    "@taxcraft/country-gb": "0.1.0",
    "@taxcraft/country-no-pit": "0.1.0",
    "@taxcraft/country-sg": "0.1.0"
  },
  "scripts": {
    "build": "node --check src/app.js && node --check src/server.js",
    "start": "node src/server.js"
  }
}

{
  "name": "taxcraft",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Deterministic personal income tax calculation engine and API.",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "check": "npm run check:policies && npm run lint && npm run build && npm test",
    "check:policies": "node scripts/validate-policies.mjs",
    "lint": "node scripts/lint.mjs",
    "start": "npm run start -w @taxcraft/api",
    "test": "node --test",
    "watch:sources": "node scripts/watch-tax-sources.mjs"
  }
}

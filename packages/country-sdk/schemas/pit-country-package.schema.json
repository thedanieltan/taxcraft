{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxcraft.dev/schemas/pit-country-package.v1.json",
  "title": "TaxCraft PIT country package manifest extension",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contractVersion",
    "taxUnit",
    "taxYearBasis",
    "currencyCodes",
    "incomeSchedules",
    "taxLayers",
    "factsSchema",
    "rounding",
    "maintenance"
  ],
  "properties": {
    "contractVersion": {
      "const": "taxcraft.pit-country-package.v1"
    },
    "taxUnit": {
      "enum": [
        "individual",
        "filing-status",
        "household",
        "household-or-filing-status"
      ]
    },
    "taxYearBasis": {
      "enum": [
        "calendar-year",
        "tax-year",
        "year-of-assessment",
        "income-year",
        "mixed"
      ]
    },
    "currencyCodes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[A-Z]{3}$"
      }
    },
    "incomeSchedules": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "taxLayers": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "national",
        "subnational",
        "local",
        "subdivisionRequired"
      ],
      "properties": {
        "national": {
          "type": "boolean"
        },
        "subnational": {
          "type": "boolean"
        },
        "local": {
          "type": "boolean"
        },
        "subdivisionRequired": {
          "type": "boolean"
        }
      }
    },
    "factsSchema": {
      "$ref": "#/$defs/factsSchema"
    },
    "rounding": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/rounding"
      }
    },
    "maintenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "sourceWatch"
      ],
      "properties": {
        "mode": {
          "enum": [
            "automated",
            "manual",
            "hybrid"
          ]
        },
        "sourceWatch": {
          "type": "boolean"
        }
      }
    }
  },
  "$defs": {
    "factsSchema": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "additionalProperties",
        "required",
        "properties"
      ],
      "properties": {
        "type": {
          "const": "object"
        },
        "additionalProperties": {
          "const": false
        },
        "required": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "properties": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "$ref": "#/$defs/fact"
          }
        }
      }
    },
    "fact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "title",
        "x-taxcraft-kind"
      ],
      "properties": {
        "type": {
          "enum": [
            "boolean",
            "integer",
            "string"
          ]
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "const": {},
        "enum": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true
        },
        "minimum": {
          "type": "integer"
        },
        "maximum": {
          "type": "integer"
        },
        "multipleOf": {
          "type": "integer",
          "minimum": 1
        },
        "x-taxcraft-kind": {
          "enum": [
            "money-minor",
            "confirmed-status",
            "enum",
            "subdivision-code",
            "count",
            "percentage-basis-points",
            "plain"
          ]
        },
        "x-taxcraft-currency": {
          "type": "string",
          "pattern": "^[A-Z]{3}$"
        }
      }
    },
    "rounding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stage",
        "mode",
        "unitMinor"
      ],
      "properties": {
        "stage": {
          "type": "string",
          "minLength": 1
        },
        "mode": {
          "enum": [
            "floor",
            "ceiling",
            "truncate",
            "half-up",
            "half-even"
          ]
        },
        "unitMinor": {
          "type": "integer",
          "minimum": 1
        }
      }
    }
  }
}

{
  "name": "taxcraft",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "taxcraft",
      "version": "0.1.0",
      "workspaces": [
        "packages/*"
      ],
      "engines": {
        "node": ">=22"
      }
    },
    "node_modules/@taxcraft/contracts": {
      "resolved": "packages/contracts",
      "link": true
    },
    "node_modules/@taxcraft/core": {
      "resolved": "packages/core",
      "link": true
    },
    "packages/contracts": {
      "name": "@taxcraft/contracts",
      "version": "0.1.0"
    },
    "packages/core": {
      "name": "@taxcraft/core",
      "version": "0.1.0",
      "dependencies": {
        "@taxcraft/contracts": "0.1.0"
      }
    }
  }
}

{
  "name": "taxcraft",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "taxcraft",
      "version": "0.1.0",
      "workspaces": [
        "apps/*",
        "packages/*"
      ],
      "engines": {
        "node": ">=22"
      }
    },
    "apps/api": {
      "name": "@taxcraft/api",
      "version": "0.1.0",
      "dependencies": {
        "@taxcraft/catalog": "0.1.0",
        "@taxcraft/core": "0.1.0",
        "@taxcraft/country-gb": "0.1.0",
        "@taxcraft/country-sg": "0.1.0"
      }
    },
    "apps/calculator": {
      "name": "@taxcraft/calculator",
      "version": "0.1.0"
    },
    "apps/worker": {
      "name": "@taxcraft/worker",
      "version": "0.1.0",
      "dependencies": {
        "@taxcraft/api": "0.1.0"
      }
    },
    "node_modules/@taxcraft/api": {
      "resolved": "apps/api",
      "link": true
    },
    "node_modules/@taxcraft/calculator": {
      "resolved": "apps/calculator",
      "link": true
    },
    "node_modules/@taxcraft/catalog": {
      "resolved": "packages/catalog",
      "link": true
    },
    "node_modules/@taxcraft/contracts": {
      "resolved": "packages/contracts",
      "link": true
    },
    "node_modules/@taxcraft/core": {
      "resolved": "packages/core",
      "link": true
    },
    "node_modules/@taxcraft/country-gb": {
      "resolved": "packages/country-gb",
      "link": true
    },
    "node_modules/@taxcraft/country-sdk": {
      "resolved": "packages/country-sdk",
      "link": true
    },
    "node_modules/@taxcraft/country-sg": {
      "resolved": "packages/country-sg",
      "link": true
    },
    "node_modules/@taxcraft/maintenance": {
      "resolved": "packages/maintenance",
      "link": true
    },
    "node_modules/@taxcraft/worker": {
      "resolved": "apps/worker",
      "link": true
    },
    "packages/catalog": {
      "name": "@taxcraft/catalog",
      "version": "0.1.0"
    },
    "packages/contracts": {
      "name": "@taxcraft/contracts",
      "version": "0.1.0"
    },
    "packages/core": {
      "name": "@taxcraft/core",
      "version": "0.1.0",
      "dependencies": {
        "@taxcraft/contracts": "0.1.0"
      }
    },
    "packages/country-gb": {
      "name": "@taxcraft/country-gb",
      "version": "0.1.0",
      "dependencies": {
        "@taxcraft/country-sdk": "0.1.0"
      }
    },
    "packages/country-sdk": {
      "name": "@taxcraft/country-sdk",
      "version": "0.1.0",
      "dependencies": {
        "@taxcraft/contracts": "0.1.0",
        "@taxcraft/core": "0.1.0"
      }
    },
    "packages/country-sg": {
      "name": "@taxcraft/country-sg",
      "version": "0.1.0",
      "dependencies": {
        "@taxcraft/country-sdk": "0.1.0"
      }
    },
    "packages/maintenance": {
      "name": "@taxcraft/maintenance",
      "version": "0.1.0"
    }
  }
}
